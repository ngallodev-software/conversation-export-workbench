{
  "_template_meta": {
    "provider": "chatgpt",
    "file_type": "conversations",
    "description": "Template for ChatGPT (OpenAI) chat export (conversations.json). Used for provider auto-detection.",
    "required_root": "array",
    "notes": [
      "Top-level value is a JSON array of conversation objects.",
      "Each conversation has a 'mapping' field (tree of message nodes) and 'current_node' (leaf of active branch).",
      "create_time and update_time are float unix timestamps (seconds), not ISO strings.",
      "Each node: { id, parent, children, message }",
      "Each message: { id, author, content, create_time, update_time, weight, metadata, ... }",
      "author.role: 'user' | 'assistant' | 'system' | 'tool'",
      "content.content_type: 'text' | 'multimodal_text' | 'tether_browse_display' | ...",
      "content.parts: array of strings (for text content_type)",
      "Walk active branch backwards from current_node via parent links, then reverse.",
      "Skip nodes where message is None, author.role == 'system', or weight == 0."
    ]
  },
  "_required_conversation_fields": ["id", "title", "create_time", "update_time", "current_node", "mapping"],
  "_required_mapping_node_fields": ["id", "children", "message", "parent"],
  "_required_message_fields": ["author", "content", "create_time", "weight"],
  "_message_roles": ["user", "assistant", "system", "tool"],
  "_content_types": {
    "text": { "parts": "array of strings" },
    "multimodal_text": { "parts": "array of strings or image refs" },
    "tether_browse_display": { "skip": true },
    "tether_quote": { "skip": true }
  },
  "_detection_signature": {
    "root_type": "array",
    "item_must_contain": ["mapping", "current_node"],
    "item_must_not_contain": ["chat_messages", "inserted_at"]
  },
