{
  "_template_meta": {
    "provider": "claude",
    "file_type": "conversations",
    "description": "Template for Claude (Anthropic) chat export (conversations.json). Used for provider auto-detection.",
    "required_root": "array",
    "notes": [
      "Top-level value is a JSON array of conversation objects.",
      "Each conversation has 'uuid', 'name', 'chat_messages' fields.",
      "Each chat_message: { uuid, sender, created_at, updated_at, content[] }",
      "sender is 'human' or 'assistant'.",
      "content blocks: { type, text } for text, { type, thinking } for extended thinking."
    ]
  },
  "_required_conversation_fields": ["uuid", "name", "created_at", "updated_at", "chat_messages"],
  "_required_message_fields": ["uuid", "sender", "created_at", "updated_at", "content"],
  "_message_senders": ["human", "assistant"],
  "_content_block_types": {
    "text":       { "required": ["type", "text"] },
    "thinking":   { "required": ["type", "thinking"] },
    "tool_use":   { "required": ["type", "id", "name", "input"] },
    "tool_result":{ "required": ["type", "tool_use_id", "content"] }
  },
  "_detection_signature": {
    "root_type": "array",
    "item_must_contain": ["chat_messages", "uuid"],
    "item_must_not_contain": ["mapping"]
  },
